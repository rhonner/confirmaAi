# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/confirmaai?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Evolution API (multi-tenant WhatsApp) - https://doc.evolution-api.com
# Each tenant gets its own instance; this single admin key manages all of them.
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-admin-api-key"
# Base URL Evolution uses to reach our webhook. In local dev with Evolution
# running in Docker, set this to http://host.docker.internal:3000 so the
# container can call back to the Next.js dev server on the host.
EVOLUTION_WEBHOOK_BASE_URL="http://host.docker.internal:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
